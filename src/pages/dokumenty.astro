---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta, documents } from '../data/site';

const title = `Dokumenty a akreditace · ${siteMeta.shortName}`;
const description =
	'Ke stažení: osvědčení akreditované laboratoře ČIA, autorizace EIA, rozptylové studie, živnostenský list a další dokumenty NATURCHEM.';
---

<BaseLayout {title} {description} canonicalPath="/dokumenty">
	<section class="section container">
		<h1 class="page-title">Dokumenty, akreditace a autorizace</h1>
		<p class="page-lead">
			Níže najdete dokumenty ve formátu PDF. Po nasazení nového webu můžete soubory zkopírovat
			do hostingu projektu — zatím odkazují na stávající cesty na{' '}
			<a href={siteMeta.url}>naturchem.cz</a>.
		</p>

		<div class="doc-grid">
			{
				documents.map((doc) => (
					<a class="surface-card doc-card" href={doc.href} target="_blank" rel="noopener">
						<span class="doc-card__title">{doc.title}</span>
						<span class="doc-card__action">Stáhnout PDF</span>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>

<style>
	.page-title {
		font-size: clamp(2rem, 3.5vw, 2.5rem);
		margin: 0 0 0.75rem;
	}

	.page-lead {
		max-width: 62ch;
		color: var(--color-muted);
		font-size: 1.05rem;
		margin: 0 0 2rem;
		line-height: 1.55;
	}

	.doc-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 0.85rem;
	}

	.doc-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		text-decoration: none;
		color: inherit;
		min-height: 100%;
		transition: transform 0.12s ease, box-shadow 0.12s ease;
	}

	.doc-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 28px rgba(27, 67, 50, 0.1);
	}

	.doc-card__title {
		font-weight: 700;
		font-size: 1rem;
		line-height: 1.35;
	}

	.doc-card__action {
		font-weight: 600;
		color: var(--color-accent);
		font-size: 0.92rem;
	}
</style>
