---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteMeta, offices, team } from '../content/site';

const title = `Kontakt · ${siteMeta.shortName}`;
const description =
	'Kontakt NATURCHEM: sídlo Havlíčkův Brod, provozovny České Budějovice a Praha. Telefon, e-mail a poptávka.';
const phonesJoined = siteMeta.phones.map((p) => p.replace(/\s/g, ''));

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	name: siteMeta.name,
	url: siteMeta.url,
	email: siteMeta.email,
	telephone: phonesJoined,
	vatID: siteMeta.dic,
	address: offices.map((o) => ({
		'@type': 'PostalAddress',
		streetAddress: `${o.street}, ${o.cityZip}`,
		addressCountry: 'CZ',
	})),
};
---

<BaseLayout {title} {description} canonicalPath="/kontakt">
	<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

	<section class="section container contact">
		<h1 class="page-title">Kontakt</h1>
		<p class="page-lead">
			Potřebujete termín měření, odborný posudek nebo konzultaci? Napište stručný popis —
			ozveme se s dalšími kroky.
		</p>

		<div class="contact__grid">
			<div class="contact__column">
				<h2 class="contact__h2">Poptávka</h2>
				<ContactForm />

				<h2 id="privacy-processing" class="contact__h2 contact__h2--spaced">
					Zpracování osobních údajů
				</h2>
				<p class="privacy">
					Údaje z formuláře zpracováváme výhradně za účelem vyřízení vaší poptávky a případné
					přípravy nabídky. Vaše zprávu nepoužíváme k newsletterům ani marketingu bez vašeho
					výslovného souhlasu.
				</p>
			</div>

			<div class="contact__column contact__aside surface-card">
				<h2 class="contact__h2">Rychlé kontakty</h2>
				<p>
					<strong>E-mail:</strong><br />
					<a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
				</p>
				<p>
					<strong>Telefon:</strong>
				</p>
				<ul class="phones">
					{
						siteMeta.phones.map((p) => (
							<li>
								<a href={`tel:${p.replace(/\s/g, '')}`}>{p}</a>
							</li>
						))
					}
				</ul>
				<p class="muted">
					<strong>IČ:</strong>
					{siteMeta.ico}
					<br />
					<strong>DIČ:</strong>
					{siteMeta.dic}
				</p>
				<p class="muted small">{siteMeta.orRejstrik}</p>

				<h3 class="contact__h3">Provozy</h3>
				<ul class="offices">
					{
						offices.map((o) => (
							<li>
								<strong>{o.label}</strong>
								<br />
								{o.street}, {o.cityZip}
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<h2 class="section-title section-title--team">Tým</h2>
		<div class="team-grid">
			{
				team.map((person) => (
					<div class="surface-card team-card">
						<p class="team-card__name">{person.name}</p>
						<p class="team-card__role">{person.role}</p>
						{person.phone && (
							<p class="team-card__phone">
								<a href={`tel:${person.phone.replace(/\s/g, '')}`}>{person.phone}</a>
							</p>
						)}
						{person.note && <p class="team-card__note">{person.note}</p>}
					</div>
				))
			}
		</div>
	</section>
</BaseLayout>

<style>
	.page-title {
		font-size: clamp(2rem, 3.5vw, 2.5rem);
		margin: 0 0 0.75rem;
	}

	.page-lead {
		max-width: 58ch;
		color: var(--color-muted);
		font-size: 1.08rem;
		margin: 0 0 2rem;
		line-height: 1.55;
	}

	.contact__grid {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: 1.5rem;
		align-items: start;
		margin-bottom: 2.5rem;
	}

	@media (max-width: 900px) {
		.contact__grid {
			grid-template-columns: 1fr;
		}
	}

	.contact__h2 {
		font-size: 1.2rem;
		margin: 0 0 1rem;
	}

	.contact__h2--spaced {
		margin-top: 2rem;
	}

	.contact__h3 {
		font-size: 1rem;
		margin: 1.25rem 0 0.5rem;
	}

	.privacy {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-muted);
		line-height: 1.55;
		max-width: 62ch;
	}

	.contact__aside p {
		margin: 0 0 0.85rem;
		line-height: 1.5;
	}

	.phones {
		list-style: none;
		margin: 0 0 1rem;
		padding: 0;
	}

	.phones li + li {
		margin-top: 0.25rem;
	}

	.offices {
		list-style: none;
		margin: 0;
		padding: 0;
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.offices li + li {
		margin-top: 0.85rem;
	}

	.muted {
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	.small {
		font-size: 0.88rem;
	}

	.section-title--team {
		font-size: 1.45rem;
		margin: 0 0 1rem;
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
		gap: 1rem;
	}

	.team-card {
		margin: 0;
	}

	.team-card__name {
		font-weight: 800;
		margin: 0 0 0.25rem;
		font-size: 1.05rem;
	}

	.team-card__role {
		margin: 0 0 0.5rem;
		font-weight: 600;
		color: var(--color-accent);
		font-size: 0.92rem;
	}

	.team-card__phone {
		margin: 0 0 0.35rem;
		font-weight: 600;
	}

	.team-card__note {
		margin: 0;
		font-size: 0.92rem;
		color: var(--color-muted);
		line-height: 1.45;
	}
</style>
