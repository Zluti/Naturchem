---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceIcon from '../../components/ServiceIcon.astro';
import { servicesNav, siteMeta, type ServiceSlug } from '../../data/site';
import { serviceDetails } from '../../data/services-detail';

export function getStaticPaths() {
	return servicesNav.map((s) => ({ params: { slug: s.slug } }));
}

const slug = Astro.params.slug as ServiceSlug;
const service = servicesNav.find((x) => x.slug === slug)!;
const detail = serviceDetails[slug];

const iconForSlug = (s: ServiceSlug) => {
	const map = {
		studie: 'studie',
		mereni: 'mereni',
		'prodej-servis': 'prodej',
		znalecka: 'znalecka',
		skoleni: 'skoleni',
	} as const;
	return map[s];
};

const title = `${service.title} · ${siteMeta.shortName}`;
const description = `${service.summary} ${detail.intro}`;
---

<BaseLayout {title} {description} canonicalPath={`/sluzby/${slug}`}>
	<div class="container section--tight">
		<nav class="breadcrumb" aria-label="Drobečková navigace">
			<a href="/">Úvod</a>
			<span class="breadcrumb__sep" aria-hidden="true">/</span>
			<a href="/sluzby">Služby</a>
			<span class="breadcrumb__sep" aria-hidden="true">/</span>
			<span class="breadcrumb__current">{service.title}</span>
		</nav>
	</div>

	<section class="section container service-detail">
		<header class="service-detail__header">
			<ServiceIcon name={iconForSlug(slug)} />
			<div>
				<h1 class="service-detail__title">{service.title}</h1>
				<p class="service-detail__intro">{detail.intro}</p>
			</div>
		</header>

		<h2 class="service-detail__h2">Co v praxi pokrýváme</h2>
		<ul class="detail-list">
			{detail.bullets.map((b) => <li>{b}</li>)}
		</ul>

		<div class="service-detail__cta surface-card">
			<p class="service-detail__cta-text">
				Potřebujete konkrétní termín, rozsah měření nebo podklad pro správní řízení?
			</p>
			<div class="service-detail__cta-actions">
				<a class="btn btn--primary" href="/kontakt">Nezávazná poptávka</a>
				<a class="btn btn--ghost" href={`mailto:${siteMeta.email}`}>Napsat e-mail</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.breadcrumb {
		font-size: 0.92rem;
		color: var(--color-muted);
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		align-items: center;
	}

	.breadcrumb a {
		font-weight: 600;
	}

	.breadcrumb__current {
		color: var(--color-text);
		font-weight: 600;
	}

	.breadcrumb__sep {
		opacity: 0.5;
	}

	.service-detail__header {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		margin-bottom: 1.5rem;
	}

	.service-detail__title {
		margin: 0 0 0.5rem;
		font-size: clamp(1.85rem, 3vw, 2.35rem);
		line-height: 1.15;
	}

	.service-detail__intro {
		margin: 0;
		font-size: 1.1rem;
		color: var(--color-muted);
		max-width: 62ch;
		line-height: 1.55;
	}

	.service-detail__h2 {
		font-size: 1.25rem;
		margin: 0 0 0.75rem;
	}

	.detail-list {
		margin: 0 0 2rem;
		padding-left: 1.2rem;
		color: var(--color-text);
		line-height: 1.55;
		max-width: 62ch;
	}

	.detail-list li + li {
		margin-top: 0.4rem;
	}

	.service-detail__cta {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-start;
		max-width: 640px;
	}

	.service-detail__cta-text {
		margin: 0;
		font-weight: 600;
		line-height: 1.45;
	}

	.service-detail__cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}
</style>
