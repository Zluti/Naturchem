---
/** Jednoduché dekorativní ikony (SVG), bez závislosti na externích fontech ikon. */
interface Props {
	name: 'studie' | 'mereni' | 'prodej' | 'znalecka' | 'skoleni';
	class?: string;
}

const { name, class: className = '' } = Astro.props;

const icons: Record<typeof name, string> = {
	studie:
		'M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8zm4 18H6V4h7v5h5zm-9 7h8v-2H9zm0-4h8v-2H9zm0-4h5v-2H9z',
	mereni:
		'M12 2a10 10 0 100 20 10 10 0 000-20zm1 14h-2v2h2zm2.07-7.75-.9.92C13.45 11.9 13 12.5 13 14h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z',
	prodej:
		'M19 7h-4V5l-2-2h-2L9 5v2H5c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zM9 5h6v2H9zm10 14H5V9h14zm-9-6h2v4h-2z',
	znalecka:
		'M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5zm0 10c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3z',
	skoleni:
		'M12 3 1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9zm6.82 6L12 12.72 5.18 9 12 5.28zm-7 9.36-.82-.44v-4.1l6 3.27 6-3.27v4.1l-6 3.27z',
};
---

<span class:list={['service-icon', className]} aria-hidden="true">
	<svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
		<path d={icons[name]} />
	</svg>
</span>

<style>
	.service-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 10px;
		background: var(--color-accent-soft);
		color: var(--color-accent);
		flex-shrink: 0;
	}
</style>
