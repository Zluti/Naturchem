---
/** Malé ikony pro USP / odrážky — čisté SVG. */
export type IconName = 'badge' | 'layers' | 'mapPin' | 'clock' | 'check';

interface Props {
	name: IconName;
	class?: string;
	size?: number;
}

const { name, class: className = '', size = 22 } = Astro.props;

const paths: Record<IconName, string> = {
	badge:
		'M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3z',
	layers:
		'M12 16 4 11 12 6l8 5zm0 5L4 16l2.5-1.56L12 18.06l5.5-3.62L20 16zm0-10L4 6 12 1l8 5z',
	mapPin:
		'M12 2a7 7 0 00-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 00-7-7zm0 9.5A2.5 2.5 0 1112 6a2.5 2.5 0 010 5.5z',
	clock:
		'M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z',
	check: 'M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z',
};
---

<span class:list={['icon-symbol', className]} aria-hidden="true">
	<svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
		<path d={paths[name]} />
	</svg>
</span>

<style>
	.icon-symbol {
		display: inline-flex;
		color: var(--color-accent);
		flex-shrink: 0;
	}
</style>
