---
import { siteMeta } from '../data/site';

interface Props {
	/** Jedinečné HTML id formuláře (kvůli více formulářům na webu). */
	formId: string;
	/** Menší rozestupy na úvodní stránce. */
	compact?: boolean;
}

const { formId, compact = false } = Astro.props;

const formspreeUrl =
	(typeof import.meta.env.PUBLIC_FORMSPREE_ENDPOINT === 'string'
		? import.meta.env.PUBLIC_FORMSPREE_ENDPOINT
		: '') || '';
const useFormspree = Boolean(formspreeUrl.trim());
---

<form
	id={formId}
	class:list={['inquiry-form', 'surface-card', compact && 'inquiry-form--compact']}
	action={useFormspree ? formspreeUrl : undefined}
	method={useFormspree ? 'post' : undefined}
	data-use-formspree={useFormspree ? 'yes' : 'no'}
	data-mail-fallback={siteMeta.email}
>
	{
		useFormspree && (
			<input type="hidden" name="_subject" value="Poptávka z naturchem.cz" />
		)
	}
	<p class="inquiry-form__lead">
		Pola označená jako povinná jsou nutná k vyřízení poptávky.
		{!useFormspree && (
			<>
				{' '}
				Odeslání otevře váš e-mailový klient se předvyplněnou zprávou na{' '}
				<strong>{siteMeta.email}</strong>.
			</>
		)}
		{' '}
		Odesláním souhlasíte se{' '}
		<a href="/kontakt#privacy-processing">zpracováním údajů</a>.
	</p>
	<div class="inquiry-form__row">
		<label class="inquiry-form__label" for={`${formId}-name`}>
			Jméno a příjmení / firma *
			<input
				id={`${formId}-name`}
				type="text"
				name="name"
				required
				autocomplete="name"
			/>
		</label>
	</div>
	<div class="inquiry-form__grid">
		<label class="inquiry-form__label" for={`${formId}-email`}>
			E-mail *
			<input
				id={`${formId}-email`}
				type="email"
				name="email"
				required
				autocomplete="email"
			/>
		</label>
		<label class="inquiry-form__label" for={`${formId}-phone`}>
			Telefon (volitelně)
			<input id={`${formId}-phone`} type="tel" name="phone" autocomplete="tel" />
		</label>
	</div>
	<label class="inquiry-form__label" for={`${formId}-topic`}>
		Typ požadavku *
		<select id={`${formId}-topic`} name="topic" required>
			<option value="">Vyberte…</option>
			<option value="studie">Studie / posudky / EIA</option>
			<option value="mereni">Akreditovaná měření</option>
			<option value="prodej">Prodej nebo servis přístrojů</option>
			<option value="znalecka">Znalecký posudek</option>
			<option value="skoleni">Školení</option>
			<option value="other">Jiné</option>
		</select>
	</label>
	<label class="inquiry-form__label" for={`${formId}-msg`}>
		Zpráva *
		<textarea id={`${formId}-msg`} name="message" rows={compact ? 4 : 5} required />
	</label>
	<label class="inquiry-form__hp visually-hidden" for={`${formId}-gotcha`}>
		Nevyplňujte, pokud jste člověk
		<input id={`${formId}-gotcha`} type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
	</label>
	<button type="submit" class="btn btn--primary inquiry-form__submit">
		{useFormspree ? 'Odeslat poptávku' : 'Otevřít e-mail s poptávkou'}
	</button>
	{
		!useFormspree && (
			<p class="inquiry-form__hint">
				Chcete odesílání přímo z webu? Nastavte na hostingu proměnnou{' '}
				<code>PUBLIC_FORMSPREE_ENDPOINT</code> (Formspree).
			</p>
		)
	}
</form>

<script define:vars={{ formId, mailFallback: siteMeta.email, useFormspree }}>
	function bindMailFallback() {
		if (useFormspree) return;
		const form = document.getElementById(formId);
		if (!(form instanceof HTMLFormElement)) return;
		form.addEventListener('submit', (event) => {
			event.preventDefault();
			const fd = new FormData(form);
			const name = String(fd.get('name') ?? '').trim();
			const email = String(fd.get('email') ?? '').trim();
			const phone = String(fd.get('phone') ?? '').trim();
			const topic = String(fd.get('topic') ?? '').trim();
			const message = String(fd.get('message') ?? '').trim();
			const lines = [
				`Jméno / firma: ${name}`,
				`E-mail: ${email}`,
				phone ? `Telefon: ${phone}` : null,
				`Typ: ${topic}`,
				'',
				message,
			].filter(Boolean);
			const subject = encodeURIComponent(`Poptávka naturchem.cz — ${topic || 'bez tématu'}`);
			const body = encodeURIComponent(lines.join('\n'));
			window.location.href = `mailto:${mailFallback}?subject=${subject}&body=${body}`;
		});
	}
	bindMailFallback();
</script>

<style>
	.inquiry-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.inquiry-form--compact {
		gap: 0.75rem;
	}

	.inquiry-form__lead {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-muted);
		line-height: 1.5;
	}

	.inquiry-form__label {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		font-weight: 600;
		font-size: 0.95rem;
	}

	.inquiry-form input,
	.inquiry-form select,
	.inquiry-form textarea {
		font: inherit;
		padding: 0.55rem 0.65rem;
		border-radius: 8px;
		border: 1px solid var(--color-border);
		background: #fff;
		color: var(--color-text);
	}

	.inquiry-form textarea {
		resize: vertical;
		min-height: 100px;
	}

	.inquiry-form__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
	}

	.inquiry-form__submit {
		align-self: flex-start;
	}

	.inquiry-form__hint {
		margin: 0;
		font-size: 0.82rem;
		color: var(--color-muted);
		line-height: 1.45;
	}

	.inquiry-form__hint code {
		font-size: 0.78rem;
		word-break: break-all;
	}

	.inquiry-form__hp {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}
</style>
