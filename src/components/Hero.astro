---
import { siteMeta } from '../data/site';

interface Props {
	title: string;
	subtitle?: string;
	pills?: readonly string[];
}

const { title, subtitle, pills = [] } = Astro.props;

const heroPhoto = siteMeta.heroPhotoSrc;
const heroAlt = siteMeta.heroPhotoAlt;
---

<section class="hero">
	<div class="hero__bg" aria-hidden="true"></div>
	<div class="container hero__grid">
		<div class="hero__copy">
			<h1 class="hero__title">{title}</h1>
			{subtitle && <p class="hero__subtitle">{subtitle}</p>}
			{
				pills.length > 0 && (
					<ul class="hero__pills">
						{pills.map((p) => (
							<li class="hero__pill">{p}</li>
						))}
					</ul>
				)
			}
			<div class="hero__actions">
				<a class="btn btn--primary" href="/kontakt#form-poptavka">Nezávazná poptávka</a>
				<a class="btn btn--ghost hero__btn-light" href="tel:+420603216983">Zavolat</a>
				<a class="btn btn--ghost hero__btn-light" href="/dokumenty">Ověřitelné dokumenty</a>
			</div>
			<p class="hero__note">
				Měření, studie a dokumentace pro úřady — Havlíčkův Brod, České Budějovice,
				Praha.
			</p>
		</div>

		<div class="hero__visual">
			<div class="hero__figure-wrap">
				<img
					class="hero__photo"
					src={heroPhoto}
					alt={heroAlt}
					width="1400"
					height="1050"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
				<img
					class="hero__pattern"
					src={siteMeta.heroPatternSrc}
					alt=""
					width="900"
					height="700"
					loading="eager"
					decoding="async"
				/>
			</div>
			<p class="hero__credit">
				Vektorová ilustrace nahraná lokálně — bez závislosti na externích obrázcích (vhodné i za firemním proxy).
			</p>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		border-bottom: 1px solid var(--color-border);
		padding-block: clamp(2.5rem, 7vw, 4.75rem);
	}

	.hero__bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(900px 420px at 12% -10%, rgba(216, 243, 220, 0.95), transparent 58%),
			radial-gradient(720px 380px at 92% 108%, rgba(149, 213, 178, 0.35), transparent 52%),
			linear-gradient(180deg, #f4faf6 0%, var(--color-bg) 100%);
		pointer-events: none;
		z-index: 0;
	}

	.hero__grid {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 1fr);
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: center;
	}

	@media (max-width: 920px) {
		.hero__grid {
			grid-template-columns: 1fr;
		}

		.hero__visual {
			order: -1;
		}
	}

	.hero__copy {
		min-width: 0;
	}

	.hero__title {
		font-size: clamp(2rem, 4.5vw, 2.85rem);
		line-height: 1.12;
		font-weight: 800;
		margin: 0 0 1rem;
		letter-spacing: -0.025em;
		color: var(--color-text);
	}

	.hero__subtitle {
		font-size: 1.17rem;
		color: var(--color-muted);
		margin: 0 0 1.15rem;
		max-width: 52ch;
		line-height: 1.58;
	}

	.hero__pills {
		list-style: none;
		margin: 0 0 1.35rem;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.hero__pill {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		padding: 0.38rem 0.72rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(45, 106, 79, 0.22);
		color: var(--color-accent-hover);
		box-shadow: 0 4px 14px rgba(27, 67, 50, 0.06);
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-bottom: 1rem;
	}

	.hero__btn-light {
		background: rgba(255, 255, 255, 0.55);
	}

	.hero__btn-light:hover {
		background: #fff;
	}

	.hero__note {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-muted);
		max-width: 46ch;
		line-height: 1.55;
	}

	.hero__figure-wrap {
		position: relative;
		border-radius: calc(var(--radius) + 10px);
		overflow: hidden;
		box-shadow: 0 28px 60px rgba(27, 67, 50, 0.2);
		border: 1px solid rgba(45, 106, 79, 0.15);
		background: #dfece3;
	}

	.hero__photo {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		object-position: center;
	}

	.hero__pattern {
		position: absolute;
		right: -14%;
		bottom: -22%;
		width: min(58%, 400px);
		height: auto;
		opacity: 0.94;
		pointer-events: none;
		filter: drop-shadow(0 14px 28px rgba(0, 0, 0, 0.1));
	}

	.hero__credit {
		margin: 0.65rem 0 0;
		font-size: 0.76rem;
		line-height: 1.45;
		color: var(--color-muted);
		max-width: 52ch;
	}

	@media (max-width: 920px) {
		.hero__pattern {
			right: -10%;
			bottom: -16%;
			width: min(48%, 320px);
		}
	}
</style>
