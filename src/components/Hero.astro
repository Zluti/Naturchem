---
interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="hero">
	<div class="container hero__inner">
		<div class="hero__copy">
			<h1 class="hero__title">{title}</h1>
			{subtitle && <p class="hero__subtitle">{subtitle}</p>}
			<div class="hero__actions">
				<a class="btn btn--primary" href="/kontakt">Nezávazná poptávka</a>
				<a class="btn btn--ghost" href="tel:+420603216983">Zavolat</a>
				<a class="btn btn--ghost" href="/dokumenty">Ověřitelné dokumenty</a>
			</div>
			<p class="hero__note">
				Měření, studie a dokumentace pro úřady — Havlíčkův Brod, České Budějovice,
				Praha.
			</p>
		</div>
	</div>
</section>

<style>
	.hero {
		background: linear-gradient(
			145deg,
			var(--color-accent-soft) 0%,
			var(--color-bg) 42%,
			#eef5f0 100%
		);
		border-bottom: 1px solid var(--color-border);
		padding-block: clamp(2.75rem, 8vw, 4.5rem);
	}

	.hero__inner {
		max-width: 720px;
	}

	.hero__title {
		font-size: clamp(2rem, 4.5vw, 2.75rem);
		line-height: 1.15;
		font-weight: 800;
		margin: 0 0 1rem;
		letter-spacing: -0.02em;
	}

	.hero__subtitle {
		font-size: 1.2rem;
		color: var(--color-muted);
		margin: 0 0 1.75rem;
		max-width: 52ch;
		line-height: 1.55;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-bottom: 1rem;
	}

	.hero__note {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-muted);
		max-width: 46ch;
	}
</style>
